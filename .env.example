APP_NAME=SignalFeed
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=Asia/Ho_Chi_Minh
APP_URL=http://localhost:8000

# Vite dev server (SPA) — CORS + Sanctum stateful domain
FRONTEND_URL=http://localhost:5173
SANCTUM_STATEFUL_DOMAINS=localhost,localhost:5173,127.0.0.1,127.0.0.1:8000,127.0.0.1:5173,::1

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ====================
# SCHEDULER & LOGGING
# ====================
# APP_TIMEZONE đã set phía trên (Asia/Ho_Chi_Minh). Production: đặt LOG_LEVEL=info.
# Crawler schedule: 01:00, 07:00, 13:00, 19:00 VN — routes/console.php
# Log files: storage/logs/
# - scheduler-YYYY-MM-DD.log (14 ngày)
# - crawler-YYYY-MM-DD.log (30 ngày)
# - crawler-errors.log (single file, dọn tay khi cần)
# Pipeline (crawl + classify): max tweets mỗi source mỗi lần chạy
# PIPELINE_TWEETS_PER_SOURCE=10

# Personal Pipeline Scheduler
# Chạy sau shared pipeline ~30 phút (ví dụ: shared lúc 1:00, personal lúc 1:30 UTC)
# Format: "minute hour * * *" hoặc full cron expression
# Default: 30 phút sau các slots của shared pipeline (1,7,13,19 UTC)
PERSONAL_PIPELINE_CRON="30 1,7,13,19 * * *"

# Signal classification (Flow 3 step 2 — TweetClassifierService / PipelineCrawlJob)
SIGNAL_THRESHOLD=0.6
CLASSIFY_BATCH_SIZE=200
CLASSIFY_LOOKBACK_HOURS=24

# Clustering (Flow 3 step 3 — TweetClusterService)
CLUSTER_LOOKBACK_HOURS=24
MIN_CLUSTER_SIZE=2
# ANTHROPIC_MODEL_CLUSTER=claude-sonnet-4-20250514
# ANTHROPIC_MAX_TOKENS_CLUSTER=4096

# --- Database: PostgreSQL 15+ (SPEC-core §3.1 / SPEC-api) ---
# Cách 1 — Chuỗi kết nối từ hosting (khuyến nghị khi có sẵn URL):
# DB_URL=postgresql://USER:PASSWORD@HOST:5432/signalfeed?sslmode=require
# Cách 2 — Tách biến (local / Docker):
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=signalfeed
# PHPUnit (phpunit.xml) ghi đè DB_DATABASE=signalfeed_test — tạo DB riêng để test không xóa dữ liệu dev
# createdb signalfeed_test  (xem docs/TESTING-DATABASE.md)
DB_USERNAME=postgres
DB_PASSWORD=
# Tuỳ host: prefer | require | disable (managed DB thường cần require)
DB_SSLMODE=prefer
# Schema Postgres (mặc định public)
DB_SCHEMA=public

SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

# --- Queue: Redis ưu tiên (SPEC-core §3.1); fallback = database (cần bảng jobs + migrate queue) ---
QUEUE_CONNECTION=redis
# Không có Redis (free tier / dev): đổi thành database hoặc sync
# QUEUE_CONNECTION=database
# QUEUE_CONNECTION=sync
# Khi dùng database driver: cùng connection app (mặc định) hoặc chỉ định:
# DB_QUEUE_CONNECTION=

CACHE_STORE=file
# Khi đã có Redis: có thể đổi CACHE_STORE=redis
CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

# Redis — queue + tùy chọn cache (extension phpredis hoặc predis)
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_URL=
# DB index trên Redis: 0 default app, 1 thường dùng cho cache (config/database.php)
REDIS_DB=0
REDIS_CACHE_DB=1

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# -----------------------------------------------------------------------------
# External services (SPEC-api.md Section 10 — service inventory / contracts)
# Chỉ placeholder; không commit giá trị thật. Lấy key từ dashboard từng nhà cung cấp.
# -----------------------------------------------------------------------------

# twitterapi.io — crawl (tweets:crawl). Key tại https://twitterapi.io/dashboard
# Base: https://api.twitterapi.io — GET /twitter/user/last_tweets?userName=&count=
# Response: { "data": { "tweets": [...] }, "status": "success", ... } (hỗ trợ cả legacy `tweets` top-level).
TWITTER_API_KEY=
# Để trống = dùng mặc định https://api.twitterapi.io
TWITTER_API_BASE_URL=
# Alias cho config `services.twitterapi.key` (cùng mục đích với TWITTER_API_KEY)
TWITTERAPI_KEY=
TWITTERAPI_BASE_URL=
TWITTERAPI_TIMEOUT=30

# X.com OAuth 2.0 (đăng nhập Socialite) — KHÁC TWITTER_API_KEY. Developer Portal → project → Keys.
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=
# Callback URL đăng ký trên X — trùng APP_URL + /auth/twitter/callback (vd. http://127.0.0.1:8000/auth/twitter/callback nếu php artisan serve --port=8000).
# Ưu tiên TWITTER_CALLBACK_URL; nếu trống dùng TWITTER_REDIRECT_URI (config/services.php).
TWITTER_CALLBACK_URL=
TWITTER_REDIRECT_URI=

# Anthropic — Claude (classify / cluster / summarize / draft). Header x-api-key.
# Lấy tại: https://console.anthropic.com/ → API Keys.
ANTHROPIC_API_KEY=
# true = FakeLLMClient (0 credits). Dev/local khuyến nghị true; production bắt buộc false khi chạy classify thật.
MOCK_LLM=true

# Stripe — thanh toán Pro/Power; server dùng secret; SPA dùng publishable (Checkout).
# Secret: https://dashboard.stripe.com/apikeys
# Publishable: cùng trang (Publishable key).
# Webhook signing secret: Developers → Webhooks → endpoint → Signing secret (cho POST /api/webhooks/stripe).
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_KEY=
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=
# Price ID từ Products → Prices; map Pro/Power trong webhook (SPEC-api / Constraint #13).
STRIPE_PRO_PRICE_ID=
STRIPE_POWER_PRICE_ID=
STRIPE_CHECKOUT_SUCCESS_URL="${APP_URL}/settings?billing=success"
STRIPE_CHECKOUT_CANCEL_URL="${APP_URL}/settings?billing=cancelled"

# Resend — gửi email digest / transactional (Section 10). Bearer Authorization.
# Lấy tại: https://resend.com/api-keys
RESEND_API_KEY=
RESEND_FROM_ADDRESS=onboarding@resend.dev
RESEND_FROM_NAME=SignalFeed
RESEND_WEBHOOK_SECRET=

# Telegram Bot API — cảnh báo Power / admin; webhook inbound nếu bật.
# Bot token: @BotFather trên Telegram → /newbot hoặc API token của bot hiện có.
# Bí mật để verify header X-Telegram-Bot-Api-Secret-Token (SPEC-api webhooks Telegram).
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=

# Chọn implementation TweetFetchProviderInterface (SPEC-core §3.2 LOCK). Không gọi vendor trực tiếp từ Service.
TWEET_FETCH_PROVIDER=twitterapi_io
